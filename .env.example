# Manifest Environment Variables
# Copy this file to .env and fill in values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DEMO_MODE=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL everywhere (prod + CI + local dev). See keel/CLAUDE.md.
# Local one-time setup: brew services start postgresql@16 && createdb manifest_dev
DATABASE_URL=postgres:///manifest_dev

# Email
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=DockLabs <info@docklabs.ai>

# Suite SSO via Keel (leave unset for standalone mode + direct Microsoft SSO)
# KEEL_OIDC_CLIENT_ID=
# KEEL_OIDC_CLIENT_SECRET=
# KEEL_OIDC_ISSUER=https://keel.docklabs.ai

# Microsoft Entra ID (Azure AD) — used when OIDC not configured
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Suite-mode integrations (leave unset for standalone deploy)
# HELM_FEED_API_KEY=

# Manifest webhook secret — HMAC for inbound packet completion webhooks from peers.
# Without this set, the webhook rejects all requests (see keel.signatures).
MANIFEST_WEBHOOK_SECRET=

# DocuSign integration (optional)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_RSA_KEY_FILE=docusign_private.pem
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
